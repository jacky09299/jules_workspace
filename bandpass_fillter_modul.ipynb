    "    final_horizontal = 0\n",
    "    total_length_fold_calc = L_fold # Store for reference\n",
    "\n",
    "    if not sols:\n",
    "        print(\"在指定的 n 範圍內未找到可行解。\")\n",
    "    else:\n",
    "        print(f\"找到 {len(sols)} 組可行解 (n, c, b_min, b_max)：\")\n",
    "        # Using the last solution found by the loop, as in the original notebook\n",
    "        n_s, c_s, b_min_s, b_max_s = sols[-1] \n",
    "        lower_horizontal = b_max_s # mm\n",
    "        upper_horizontal = lower_horizontal # mm\n",
    "        initial_horizontal = lower_horizontal # mm\n",
    "        vertical_line = c_s # mm\n",
    "        lower_vertical = c_s / 2 # mm\n",
    "        upper_vertical = c_s / 2 # mm\n",
    "        n_folds = int(n_s) # Ensure n_folds is an integer\n",
    "        \n",
    "        print(f\"Using: n={n_folds}, vertical_line={vertical_line:.3f}mm, lower_horizontal={lower_horizontal:.3f}mm\")\n",
    "    \n",
    "    # 傳輸線參數\n",
    "    folded_TL_width, folded_TL_gap = '0.010mm', '0.006mm'\n",
    "    \n",
    "    if n_folds > 0: # Proceed only if valid parameters were found\n",
    "        one_fold_unit = upper_vertical + upper_horizontal + vertical_line + lower_horizontal + lower_vertical\n",
    "        used_length = initial_horizontal\n",
    "        remaining_length = total_length_fold_calc - used_length\n",
    "        final_horizontal = remaining_length - (n_folds * one_fold_unit)\n",
    "        print(f\"折疊單元數量: {n_folds}\")\n",
    "        print(f\"最後橫線長度: {final_horizontal:.3f}mm\")\n",
    "\n",
    "        # 產生 folded_path (OrderedDict, value 為 tuple of numbers)\n",
    "        # Ensure port_L4 exists if we are calculating start_x, start_y from it\n",
    "        if 'port_L4' in design.components and draw_config.get(\"port_L4\", True):\n",
    "            start_x_fold = parse_value(port_L4.options.pos_x) + 0.2 # mm, 0.2 is lead\n",
    "            start_y_fold = parse_value(port_L4.options.pos_y) # mm\n",
    "        else: # Fallback if port_L4 is not drawn - this will likely cause issues if folded_TL is drawn\n",
    "            start_x_fold = -parse_value(x_port) + 0.2 # Default based on port_L4 original position logic\n",
    "            start_y_fold = -parse_value(y_port)\n",
    "            print(\"Warning: port_L4 not found or not drawn, using default start for folded_TL path calc.\")\n",
    "\n",
    "        current_x_fold, current_y_fold = start_x_fold, start_y_fold\n",
    "        folded_path[0] = (current_x_fold, current_y_fold)\n",
    "        path_index = 1\n",
    "        for i in range(n_folds):\n",
    "            current_y_fold += upper_vertical\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold); path_index += 1\n",
    "            current_x_fold += upper_horizontal\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold); path_index += 1\n",
    "            current_y_fold -= vertical_line\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold); path_index += 1\n",
    "            current_x_fold += lower_horizontal\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold); path_index += 1\n",
    "            current_y_fold += lower_vertical\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold); path_index += 1\n",
    "        \n",
    "        if final_horizontal > 1e-6: # Check for non-negligible length\n",
    "            current_x_fold += final_horizontal\n",
    "            folded_path[path_index] = (current_x_fold, current_y_fold)\n",
    "        print(f\"Calculated end x for folded_path (before lead): {current_x_fold:.3f}mm\")\n",
    "    else:\n",
    "        print(\"Skipping folded_path generation as no valid n_folds found.\")\n",
    "else:\n",
    "    print(\"Skipping folded_TL parameter calculations as it's not configured to be drawn.\")\n",
    "    # Define folded_path as empty or with a dummy entry if other components might try to access it.\n",
    "    folded_path = OrderedDict() \n",
    "    n_folds = 0 # Ensure n_folds is defined for cell 16 if this block is skipped\n",
    "\n",
    "# Actual drawing of folded_TL is in the next cell.\n",
    "# This cell just prepares folded_path, n_folds, etc.\n",
    "gui.rebuild() # Rebuild to show any VirtualJunctions or other minor things if any\n",
    "gui.autoscale()\n",
    "# gui.screenshot() # Screenshot after actual drawing in next cell"
   ]
