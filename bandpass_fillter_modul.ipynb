    "class LShapedCPW:\n",
    "    \"\"\"\n",
    "    通用的 L 型 CPW 走线类。\n",
    "    Modified to use numeric coordinates internally and add units only at QComponent creation.\n",
    "    Relies on `folded_path` (numeric) and `s` (numeric, in mm) passed to `get_xy_on_folded_path`.\n",
    "    \"\"\"\n",
    "    TYPES = (\"initial_L\", \"right_L\", \"left_L\", \"bottom_L\", \"top\", \"end_L\")\n",
    "\n",
    "    def __init__(self, design_obj, name,\n",
    "                 # start_x, start_y, # These will be determined by s_val_on_main_tl\n",
    "                 total_length_mm, # numeric\n",
    "                 trace_width_str=\"10um\", trace_gap_str=\"6um\", fillet_str='0.01mm',\n",
    "                 trace_type_str=None, # Optional, can be auto-determined\n",
    "                 main_folded_path_numeric=None, # The main 'folded_TL' path (numeric)\n",
    "                 s_val_on_main_tl_mm=None, # Numeric distance along main_folded_path_numeric\n",
    "                 main_tl_total_len_mm=None): # Total length of the main folded_TL component\n",
    "        self.design = design_obj\n",
    "        self.name = name\n",
    "        self.total_length_mm = total_length_mm\n",
    "        self.trace_width_str = trace_width_str\n",
    "        self.trace_gap_str = trace_gap_str\n",
    "        self.fillet_str = fillet_str\n",
    "        self.main_folded_path_numeric = main_folded_path_numeric\n",
    "        self.s_val_on_main_tl_mm = s_val_on_main_tl_mm\n",
    "        self.main_tl_total_len_mm = main_tl_total_len_mm\n",
    "\n",
    "        self.start_component_name = \"\" # Name of the component to connect to (e.g., 'folded_TL' or a VirtualJunction)\n",
    "        self.start_pin_name = \"\"      # Name of the pin on the start_component_name\n",
    "        self.short_name = f\"{self.name}_stg\" # Name for the ShortToGround termination\n",
    "\n",
    "        # Determine start_x, start_y (numeric) based on s_val_on_main_tl_mm\n",
    "        if self.main_folded_path_numeric and self.s_val_on_main_tl_mm is not None and 'port_L4' in self.design.components and 'port_R4' in self.design.components:\n",
    "            # Get total length of the folded_TL component if it exists\n",
    "            # This is tricky as component length isn't always straightforward before full build.\n",
    "            # The 'total_length_fold_calc' from cell 12 is the design target length.\n",
    "            # For now, assume main_tl_total_len_mm is provided accurately.\n",
    "            self.start_x_mm, self.start_y_mm = get_xy_on_folded_path(\n",
    "                self.main_folded_path_numeric, \n",
    "                self.s_val_on_main_tl_mm, \n",
    "                self.design.components['port_L4'].options, \n",
    "                self.design.components['port_R4'].options,\n",
    "                self.main_tl_total_len_mm if self.main_tl_total_len_mm else 49.61576 # Fallback to hardcoded total length\n",
    "            )\n",
    "        else:\n",
    "            # Fallback or error if dependencies for calculating start_x/y are missing\n",
    "            print(f\"Warning: Could not determine start_x/y for {self.name}. Using (0,0). Check folded_path and s_val.\")\n",
    "            self.start_x_mm, self.start_y_mm = 0.0, 0.0\n",
    "            # This component should not be built if this happens.\n",
    "            # The calling code in cell 15 should check draw_config[\"folded_TL\"]\n",
    "            return\n",
    "\n",
    "        self.trace_type = trace_type_str or self._determine_type()\n",
    "        if self.trace_type not in self.TYPES:\n",
    "            raise ValueError(f\"Unknown trace type {self.trace_type} for {self.name}\")\n",
    "\n",
    "        # Call the builder for the determined type\n",
    "        getattr(self, f\"_build_{self.trace_type}\")()\n",
    "\n",
    "    def _determine_type(self):\n",
    "        # This logic is from the original notebook and might need adjustment based on how 's' is interpreted\n",
    "        # relative to the segments of the main folded path.\n",
    "        # The original logic used s values like 0.1, 9.07, etc.\n",
    "        s_adjusted = self.s_val_on_main_tl_mm # Using the direct s value passed\n",
    "        lead_start_main = 0.1 # lead of main folded_TL\n",
    "        # total_length_main is the L_fold = 49.61576, but RouteAnchors has its own leads\n",
    "        # This part needs to be robust. For now, use the hardcoded values from original for type determination.\n",
    "\n",
    "        if s_adjusted <= 0.2: # Original condition was s <= 0.2 (referring to start lead of folded_TL)\n",
    "            return \"initial_L\"\n",
    "        # Assuming main_tl_total_len_mm is the full length of the 'folded_TL' component from RouteAnchors\n",
    "        if self.main_tl_total_len_mm and s_adjusted >= self.main_tl_total_len_mm - 0.1: # End lead of folded_TL\n",
    "            return \"end_L\"\n",
    "        \n",
    "        # The intermediate type determination is complex as it depends on which segment of the folded path 's' falls on.\n",
    "        # The original notebook's _determine_type in LShapedCPW had logic based on iterating through segments of folded_path.\n",
    "        # Replicating that segment-based logic here:\n",
    "        if not self.main_folded_path_numeric or len(self.main_folded_path_numeric) < 2:\n",
    "            return \"initial_L\" # Fallback\n",
    "\n",
    "        # s_val_on_main_tl_mm is along the main path including its leads (0.1mm start, 0.1mm end for RouteAnchors)\n",
    "        # We need s relative to the *anchors* part of main_folded_path_numeric\n",
    "        s_on_anchors = self.s_val_on_main_tl_mm - 0.1 # Subtract start lead of RouteAnchors\n",
    "\n",
    "        points = list(self.main_folded_path_numeric.values()) # These are the points used to define the anchors\n",
    "        seg_lens = [np.hypot(points[i+1][0]-points[i][0], points[i+1][1]-points[i][1]) for i in range(len(points)-1)]\n",
    "        \n",
    "        current_path_len = 0\n",
    "        for i, seg_len in enumerate(seg_lens):\n",
    "            if current_path_len + seg_len >= s_on_anchors:\n",
    "                # s is on segment i (from point i to point i+1)\n",
    "                # The original logic used idx_mod = i % 5 based on the 5-segment fold unit.\n",
    "                # 0: upper_vertical, 1: upper_horizontal, 2: vertical_line, 3: lower_horizontal, 4: lower_vertical\n",
    "                idx_mod = i % 5 \n",
    "                if idx_mod == 0: return \"right_L\" # Start of up-going vertical, L-shape goes right then down\n",
    "                elif idx_mod == 1: return \"top\"     # On upper horizontal, L-shape goes straight down\n",
    "                elif idx_mod == 2: return \"left_L\"  # Start of down-going vertical, L-shape goes left then down\n",
    "                elif idx_mod == 3: return \"bottom_L\"# On lower horizontal, L-shape goes down then right\n",
    "                elif idx_mod == 4: return \"right_L\" # End of down-going vertical (start of next up-going), L-shape goes right then down\n",
    "            current_path_len += seg_len\n",
    "        return \"end_L\" # Fallback if s is past all segments (e.g. on end lead)\n",
    "\n",
    "    def _add_short(self, x_mm, y_mm, orientation_str):\n",
    "        ShortToGround(self.design, self.short_name,\n",
    "                      options=dict(pos_x=f'{x_mm}mm', pos_y=f'{y_mm}mm', orientation=orientation_str))\n",
    "\n",
    "    def _add_route(self, anchors_numeric_dict):\n",
    "        anchors_str_units = OrderedDict()\n",
    "        for k, v_tuple in anchors_numeric_dict.items():\n",
    "            anchors_str_units[str(k)] = (f\"{v_tuple[0]}mm\", f\"{v_tuple[1]}mm\")\n",
    "        \n",
    "        RouteAnchors(self.design, self.name,\n",
    "            options=dict(\n",
    "                pin_inputs=dict(\n",
    "                    start_pin=dict(component=self.start_component_name, pin=self.start_pin_name),\n",
    "                    end_pin=dict(component=self.short_name, pin=\"short\")\n",
    "                ),\n",
    "                trace_width=self.trace_width_str,\n",
    "                trace_gap=self.trace_gap_str,\n",
    "                fillet=self.fillet_str,\n",
    "                anchors=anchors_str_units\n",
    "            ))\n",
    "\n",
    "    def _setup_start_pin_on_main_tl(self, pin_direction_from_junction):\n",
    "        # Create a VirtualJunction on the main folded_TL at self.start_x_mm, self.start_y_mm\n",
    "        # The LShapedCPW will connect to this junction.\n",
    "        junction_name = f\"{self.name}_start_junction\"\n",
    "        VirtualJunction(self.design, junction_name, options=dict(\n",
    "            pos_x=f'{self.start_x_mm}mm',\n",
    "            pos_y=f'{self.start_y_mm}mm',\n",
    "            pin_width=self.trace_width_str # Match CPW width\n",
    "        ))\n",
    "        self.start_component_name = junction_name\n",
    "        self.start_pin_name = pin_direction_from_junction # e.g., 'bottom', 'left', 'right'\n",
    "\n",
    "    def _build_initial_L(self):\n",
    "        down_mm = 0.6\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        short_x_mm = sx_mm + (self.total_length_mm - down_mm)\n",
    "        short_y_mm = sy_mm - down_mm\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"0\")\n",
    "        self._setup_start_pin_on_main_tl('bottom') # Connects to 'bottom' pin of the junction\n",
    "        anchors = {\"0\": (sx_mm, short_y_mm)} # Single anchor point for the turn\n",
    "        self._add_route(anchors)\n",
    "\n",
    "    def _build_right_L(self):\n",
    "        small_mm = 0.05\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        mid_x_mm = sx_mm + small_mm\n",
    "        mid_y_mm = sy_mm \n",
    "        short_x_mm = mid_x_mm\n",
    "        short_y_mm = sy_mm - (self.total_length_mm - small_mm)\n",
    "\n",
    "        # Original logic had a re-fold if short_y was too low. Simplified for now.\n",
    "        # This part might need port_R4.options.pos_y if that logic is restored.\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"270\")\n",
    "        self._setup_start_pin_on_main_tl('right') # Connects to 'right' pin of the junction\n",
    "        anchors = {\"0\": (mid_x_mm, mid_y_mm)}\n",
    "        self._add_route(anchors)\n",
    "\n",
    "    def _build_left_L(self):\n",
    "        small_mm = 0.05\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        mid_x_mm = sx_mm - small_mm\n",
    "        mid_y_mm = sy_mm\n",
    "        short_x_mm = mid_x_mm\n",
    "        short_y_mm = sy_mm - (self.total_length_mm - small_mm)\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"270\")\n",
    "        self._setup_start_pin_on_main_tl('left') # Connects to 'left' pin of the junction\n",
    "        # For RouteStraight implementation, would need two RouteStraights and a middle VirtualJunction\n",
    "        # For RouteAnchors:\n",
    "        anchors = {\"0\": (mid_x_mm, mid_y_mm)}\n",
    "        self._add_route(anchors)\n",
    "\n",
    "    def _build_bottom_L(self):\n",
    "        down_mm = 0.2\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        mid_x_mm = sx_mm\n",
    "        mid_y_mm = sy_mm - down_mm\n",
    "        short_x_mm = sx_mm + (self.total_length_mm - down_mm)\n",
    "        short_y_mm = mid_y_mm\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"0\")\n",
    "        self._setup_start_pin_on_main_tl('bottom') # Connects to 'bottom' pin of the junction\n",
    "        anchors = {\"0\": (mid_x_mm, mid_y_mm)}\n",
    "        self._add_route(anchors)\n",
    "\n",
    "    def _build_top(self):\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        short_x_mm = sx_mm\n",
    "        short_y_mm = sy_mm - self.total_length_mm\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"270\")\n",
    "        self._setup_start_pin_on_main_tl('bottom') # Connects to 'bottom' pin of the junction\n",
    "        # This is a straight line, so no intermediate anchors needed for RouteAnchors\n",
    "        # If RouteStraight is preferred: \n",
    "        # RouteStraight(self.design, self.name, options=dict(\n",
    "        #     pin_inputs=dict(start_pin=dict(component=self.start_component_name, pin=self.start_pin_name),\n",
    "        #                     end_pin=dict(component=self.short_name, pin=\"short\")),\n",
    "        #     trace_width=self.trace_width_str, trace_gap=self.trace_gap_str))\n",
    "        self._add_route(OrderedDict()) # Empty anchors for a direct connection\n",
    "\n",
    "    def _build_end_L(self):\n",
    "        down_mm = 0.8 # Original was 0.8, but in initial_L it was 0.6. Keeping 0.8 from original end_L.\n",
    "        sx_mm, sy_mm = self.start_x_mm, self.start_y_mm\n",
    "        mid_x_mm = sx_mm\n",
    "        mid_y_mm = sy_mm - down_mm\n",
    "        short_x_mm = sx_mm - (self.total_length_mm - down_mm)\n",
    "        short_y_mm = mid_y_mm\n",
    "        self._add_short(short_x_mm, short_y_mm, orientation_str=\"180\")\n",
    "        self._setup_start_pin_on_main_tl('bottom') # Connects to 'bottom' pin of the junction\n",
    "        anchors = {\"0\": (mid_x_mm, mid_y_mm)}\n",
    "        self._add_route(anchors)"
   ]
