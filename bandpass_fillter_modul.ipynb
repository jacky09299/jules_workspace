    "# This cell creates VirtualJunctions on the folded_TL and routes to coupling pads.\n",
    "# It depends on folded_TL (for n_folds, folded_path) and coupling_pad1/3 assemblies.\n",
    "\n",
    "# Create VirtualJunctions on folded_TL first, if folded_TL is drawn\n",
    "if draw_config.get(\"folded_TL\", True) and 'folded_TL' in design.components and len(folded_path) > 1 and n_folds > 0:\n",
    "    # folded_path here is the numeric version from cell 12\n",
    "    for i in range(n_folds): # n_folds also from cell 12\n",
    "        # Logic for finding midpoint of upper horizontal segment of each fold\n",
    "        # The path indices for upper horizontal segment: starts at 1 + i*5, ends at 2 + i*5\n",
    "        idx_start_segment = 1 + i * 5 \n",
    "        idx_end_segment = 2 + i * 5\n",
    "        if idx_end_segment >= len(folded_path): # Path is indexed 0 to len-1\n",
    "            print(f\"Warning: Not enough points in folded_path to create couple_point{i+1}. Max index={len(folded_path)-1}, needed={idx_end_segment}\")\n",
    "            break\n",
    "        \n",
    "        # folded_path values are tuples of numbers (mm)\n",
    "        x0_fp, y0_fp = folded_path[idx_start_segment]\n",
    "        x1_fp, y1_fp = folded_path[idx_end_segment]\n",
    "        xm_fp = (x0_fp + x1_fp) / 2\n",
    "        ym_fp = (y0_fp + y1_fp) / 2\n",
    "        \n",
    "        VirtualJunction(design, f\"couple_point{i+1}\", options=dict(\n",
    "            pos_x=f'{xm_fp}mm', pos_y=f'{ym_fp}mm', pin_width='10um'))\n",
    "\n",
    "if draw_config.get(\"coupling_pad1_assembly\", True) and 'coupling_pad1_node' in design.components and \\\n",
    "   draw_config.get(\"folded_TL\", True) and 'couple_point15' in design.components: # Check dependencies\n",
    "    RoutePathfinder(design, 'cpw_couple1',\n",
    "        options=dict(trace_width='10um', trace_gap='6um', fillet='0.01mm', hfss_wire_bonds=True,\n",
    "            lead=dict(start_straight='0.1mm', end_straight='0.1mm'),\n",
    "            pin_inputs=dict(\n",
    "                start_pin=dict(component='couple_point15', pin='right'), # Assuming couple_point15 is on a horizontal segment, pin 'right' or 'left'\n",
    "                end_pin=dict(component='coupling_pad1_node', pin='left') # Assuming U-shape node needs 'left' connection\n",
    "            )))\n",
    "\n",
    "if draw_config.get(\"coupling_pad3_assembly\", True) and 'coupling_pad3_node' in design.components and \\\n",
    "   draw_config.get(\"folded_TL\", True) and 'couple_point20' in design.components: # Check dependencies\n",
    "    RoutePathfinder(design, 'cpw_couple2',\n",
    "        options=dict(trace_width='10um', trace_gap='6um', fillet='0.01mm', hfss_wire_bonds=True,\n",
    "            lead=dict(start_straight='0.1mm', end_straight='0.1mm'),\n",
    "            pin_inputs=dict(\n",
    "                start_pin=dict(component='couple_point20', pin='right'),\n",
    "                end_pin=dict(component='coupling_pad3_node', pin='left')\n",
    "            )))\n",
    "\n",
    "gui.rebuild()\n",
    "gui.autoscale()\n",
    "gui.screenshot()"
   ]
  },
