    "class UShapeComponent:\n",
    "    \"\"\"\n",
    "    U形元件類別. Ensure units are handled (e.g. by passing strings like '0.3mm').\n",
    "    \"\"\"\n",
    "    def __init__(self, design_obj, base_name='u_shape', bl_str='0.3mm', sh_str='0.1mm', tw_str='0.01mm'):\n",
    "        self.design = design_obj\n",
    "        self.base_name = base_name\n",
    "        self.bl_str = bl_str\n",
    "        self.sh_str = sh_str\n",
    "        self.tw_str = tw_str\n",
    "        self.rect_bottom = None\n",
    "        self.rect_left = None\n",
    "        self.rect_right = None\n",
    "        self.node = None # For the VirtualJunction\n",
    "    \n",
    "    def create(self, cx_str, cy_str):\n",
    "        cx_val = parse_value(cx_str)\n",
    "        cy_val = parse_value(cy_str)\n",
    "        bl_val = parse_value(self.bl_str)\n",
    "        sh_val = parse_value(self.sh_str)\n",
    "        tw_val = parse_value(self.tw_str)\n",
    "\n",
    "        self.rect_bottom = Rectangle(\n",
    "            self.design, f'{self.base_name}_bottom', \n",
    "            options=dict(pos_x=cx_str, pos_y=cy_str, width=self.bl_str, height=self.tw_str))\n",
    "        \n",
    "        left_x_str = str(cx_val - bl_val / 2 + tw_val / 2) + 'mm'\n",
    "        left_y_str = str(cy_val + sh_val / 2 - tw_val / 2) + 'mm' # Original was + sh/2 - tw/2. Assuming U opens upwards.\n",
    "        self.rect_left = Rectangle(\n",
    "            self.design, f'{self.base_name}_left',\n",
    "            options=dict(pos_x=left_x_str, pos_y=left_y_str, width=self.tw_str, height=self.sh_str))\n",
    "        \n",
    "        right_x_str = str(cx_val + bl_val / 2 - tw_val / 2) + 'mm'\n",
    "        right_y_str = str(cy_val + sh_val / 2 - tw_val / 2) + 'mm'\n",
    "        self.rect_right = Rectangle(\n",
    "            self.design, f'{self.base_name}_right',\n",
    "            options=dict(pos_x=right_x_str, pos_y=right_y_str, width=self.tw_str, height=self.sh_str))\n",
    "\n",
    "        self.node = VirtualJunction(self.design, f\"{self.base_name}_node\", options=dict(\n",
    "            pos_x=cx_str, pos_y=cy_str, pin_width='10um'))\n",
    "        return self\n",
    "\n",
    "# Convenience function from notebook\n",
    "def create_u_shape(design_obj, cx_str, cy_str, name='u_shape', bl_str='0.3mm', sh_str='0.1mm', tw_str='0.01mm'):\n",
    "    u_shape = UShapeComponent(design_obj, name, bl_str, sh_str, tw_str)\n",
    "    u_shape.create(cx_str, cy_str)\n",
    "    return u_shape\n",
    "\n",
