    "    # For CPWTee, we'd provide pin_inputs for where the tee connects.\n",
    "    # The original Round_Tee seemed to create its own internal pins based on 'ref_qc'.\n",
    "    # This is a major difference. For now, assuming Round_Tee custom component exists and works as intended.\n",
    "    tee1_options = dict(ref_qc = Q1, rel_ori = \"90\", \n",
    "                        shift_x = f'{shift_x1}mm', shift_y = f'{shift_y1}mm',\n",
    "                        cpw_width = res_width, cpw_gap = res_gap, ext_len = f'{R_ext1}mm', \n",
    "                        tee_width = f'{tee_width_val}mm', tee_length = f'{tee_length_val}mm', \n",
    "                        tee_fillet = f'{tee_fillet_val}mm')\n",
    "    Tee_1 = Round_Tee(design, \"Tee_1\", options=tee1_options)\n",
    "\n",
    "    stg_q1_pos_x = Q1.options.pos_x\n",
    "    stg_q1_pos_y = str(parse_value(Tee_1.options.pos_y) + parse_value(Tee_1.options.tee_width)/2 + parse_value(Tee_1.options.ext_len)) + 'mm' # Approximate, depends on Round_Tee internal logic\n",
