    "def get_xy_on_folded_path(fp_numeric, s_val_mm, port_L4_options, port_R4_options, total_len_mm):\n",
    "    \"\"\"\n",
    "    給定folded_path (OrderedDict, key為int, value為(x,y) numeric), 長度s (mm),\n",
    "    port options for lead adjustment, and total length.\n",
    "    回傳走s後的(x, y)座標 (numeric).\n",
    "    \"\"\"\n",
    "    import numpy as np\n",
    "    lead_start = 0.2 # mm, hardcoded from original path generation for folded_path[0]\n",
    "    # The end lead for port_R4 is 0.1mm in RouteAnchors, but the path itself extends fully.\n",
    "    # The s_val_mm is along the full drawn length including leads of RouteAnchors.\n",
    "\n",
    "    if not port_L4_options or not port_R4_options:\n",
    "        # Fallback if ports are not available, this will be inaccurate\n",
    "        # This situation should ideally be handled by not calling this function if deps are missing\n",
    "        print(\"Warning: Port L4/R4 options missing in get_xy_on_folded_path, results may be inaccurate.\")\n",
    "        # A dummy return or raise error might be better\n",
    "        if len(fp_numeric) > 0:\n",
    "             return fp_numeric[0] if s_val_mm <= lead_start else list(fp_numeric.values())[-1]\n",
    "        return (0,0) \n",
    "\n",
    "    port_L4_pos_x = parse_value(port_L4_options.pos_x)\n",
    "    port_L4_pos_y = parse_value(port_L4_options.pos_y)\n",
    "    port_R4_pos_x = parse_value(port_R4_options.pos_x)\n",
    "    port_R4_pos_y = parse_value(port_R4_options.pos_y)\n",
    "\n",
    "    # RouteAnchors lead definitions for folded_TL\n",
    "    route_lead_start = 0.100 # mm\n",
    "    route_lead_end = 0.100   # mm\n",
    "\n",
    "    if s_val_mm <= route_lead_start:\n",
    "        return (port_L4_pos_x + s_val_mm, port_L4_pos_y) # Moving along port_L4's orientation (assuming 0 deg)\n",
    "    \n",
    "    # total_len_mm is the total length of the RouteAnchors component 'folded_TL'\n",
    "    # If s_val_mm is near the end, it's along the end lead from port_R4\n",
    "    if s_val_mm >= total_len_mm - route_lead_end:\n",
    "        dist_from_end_pin = total_len_mm - s_val_mm\n",
    "        return (port_R4_pos_x - dist_from_end_pin, port_R4_pos_y) # Moving from port_R4's tie point (assuming 180 deg)\n",
    "\n",
    "    # Adjust s to be along the `anchors` part of the path\n",
    "    s_on_anchors = s_val_mm - route_lead_start\n",
    "    \n",
    "    if not fp_numeric or len(fp_numeric) < 2:\n",
    "        # Not enough points to define segments, return start or end based on s_on_anchors\n",
    "        if len(fp_numeric) == 1:\n",
    "            return list(fp_numeric.values())[0]\n",
    "        return (port_L4_pos_x + route_lead_start, port_L4_pos_y) # Default to end of start lead\n",
    "\n",
    "    points = list(fp_numeric.values()) # These points are numeric, from the previous cell's folded_path\n",
    "    seg_lens = [np.hypot(points[i+1][0]-points[i][0], points[i+1][1]-points[i][1]) for i in range(len(points)-1)]\n",
    "    \n",
    "    # Calculate total length of the anchors part\n",
    "    anchors_total_len = sum(seg_lens)\n",
    "    if s_on_anchors > anchors_total_len: # s is beyond the anchors path\n",
    "        return points[-1] # Return the last point of the anchors\n",
    "    if s_on_anchors < 0: # s is before the anchors path (should be covered by lead checks)\n",
    "        return points[0]\n",
    "\n",
    "    current_path_len = 0\n",
    "    for i, seg_len in enumerate(seg_lens):\n",
    "        if current_path_len + seg_len >= s_on_anchors:\n",
    "            # Point is in this segment\n",
    "            remainder_len = s_on_anchors - current_path_len\n",
    "            x0, y0 = points[i]\n",
    "            x1, y1 = points[i+1]\n",
    "            ratio = remainder_len / seg_len if seg_len != 0 else 0\n",
    "            x = x0 + (x1 - x0) * ratio\n",
    "            y = y0 + (y1 - y0) * ratio\n",
    "            return (x, y)\n",
    "        current_path_len += seg_len\n",
    "    \n",
    "    return points[-1] # Fallback: return last point if s_on_anchors matches anchors_total_len exactly"
   ]
  },
