    "    R_ext1, shift_x1, shift_y1 = 0.200, 0, 0.309 # mm values\n",
    "\n",
    "    # Tee_1 - Using placeholder Round_Tee which is CPWTee\n",
    "    # CPWTee needs direct pos_x, pos_y. Original Round_Tee calculated this from ref_qc (Q1)\n",
    "    # We need to calculate the absolute position for CPWTee based on Q1's position and shifts.\n",
