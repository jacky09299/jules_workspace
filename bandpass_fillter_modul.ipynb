    "def find_bc_solutions(L, delta, max_n=100):\n",
    "    \"\"\"\n",
    "    在 n = 1,2,...,max_n 範圍內搜尋 (b, c) 解。\n",
    "    條件：\n",
    "      n = (L - delta) / (2c) 為正整數\n",
    "      floor((L-b)/(2*(b+c))) == n  == (L-delta)/(2c)\n",
    "    回傳值：一個 list，每項為 (n, c, b_min, b_max)，\n",
    "      其中 b_min < b <= b_max。\n",
    "    \"\"\"\n",
    "    solutions = []\n",
    "    for n in range(1, max_n+1):\n",
    "        # 計算 c\n",
    "        if (2 * n) == 0: continue # Avoid division by zero\n",
    "        c = (L - delta) / (2 * n)\n",
    "        if c <= 1e-9: # c must be positive and practical\n",
    "            continue\n",
    "        \n",
    "        # 計算 b 的不等式邊界\n",
    "        # Denominator for b_min: n*(2*n+3)\n",
    "        denom_b_min = n * (2 * n + 3)\n",
    "        if abs(denom_b_min) < 1e-9: continue # Avoid division by zero\n",
    "        b_min = ((n + 1) * delta - L) / denom_b_min  # 下界 (strict)\n",
    "\n",
    "        # Denominator for b_max: (2*n+1)\n",
    "        denom_b_max = (2 * n + 1)\n",
    "        if abs(denom_b_max) < 1e-9: continue # Avoid division by zero\n",
    "        b_max = delta / denom_b_max                  # 上界 (inclusive)\n",
    "\n",
    "        # 判斷是否有可行 b\n",
    "        if b_min < b_max and b_max > 0.1: # Original condition b_max > 0.1 seems arbitrary, might need adjustment\n",
    "            solutions.append((n, c, b_min, b_max))\n",
    "            print(f\"n={n}, c={c:.3f}, b_min={b_min:.3f}, b_max={b_max:.3f}\")\n",
    "    return solutions"
   ]
  },
